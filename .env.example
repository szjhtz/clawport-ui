# Path to your OpenClaw workspace directory
WORKSPACE_PATH=/Users/yourname/.openclaw/workspace

# Path to the openclaw CLI binary
OPENCLAW_BIN=/usr/local/bin/openclaw

# OpenClaw gateway token — authenticates all API calls (chat, vision, TTS, transcription)
# Find yours: openclaw gateway status (or check your gateway config)
OPENCLAW_GATEWAY_TOKEN=your-token-here

# ElevenLabs API key — optional, used for voice indicators on agent profiles
ELEVENLABS_API_KEY=sk_...
